// Helper for generating random values
func generateRandomString(n int) string {
	letterRunes := []rune("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789")
    b := make([]rune, n)
    for i := range b {
        b[i] = letterRunes[rand.Intn(len(letterRunes))]
    }
    return string(b)
}

// Truncates a string to n characters and adds ... if it exceeded the limit.
func truncate(s string, n int) string {
	if len(s) <= n {
		return s
	}
	return s[:n] + "..."
}

// New unique ID generator
var idCounter int64

func nextID() string {
	idCounter++
	return fmt.Sprintf("%d", idCounter)
}

// Rates the errors for specific error types
func isRateLimitError(err error) bool {
	return strings.Contains(err.Error(), "rate limit") || 
	       strings.Contains(err.Error(), "429") || 
	       strings.Contains(err.Error(), "529")
}

func isServiceError(err error) bool {
	return strings.Contains(err.Error(), "service") || 
	       strings.Contains(err.Error(), "529") || 
	       strings.Contains(err.Error(), "overloaded")
}

func (r *RecoveryState) incrementConsecutive529() {
    r.Consecutive529++
    if r.Consecutive529 >= MAX_CONSECUTIVE_529 {
        r.HasEscalated = true
    }
}

func (r *RecoveryState) resetConsecutive529() {
    r.Consecutive529 = 0
}

// Parse frontmatter of a markdown document
func parseFrontmatter(text string) (map[string]interface{}, string) {
    if !strings.HasPrefix(text, "---") {
        return {}, text
    }
    parts := strings.SplitN(text, "---", 3)
    if len(parts) < 3 {
        return {}, text
    }
    meta := make(map[string]interface{})
    if err := yaml.Unmarshal([]byte(parts[1]), &meta); err != nil {
        meta = make(map[string]interface{})
    }
    return meta, strings.TrimSpace(parts[2])
}

// Scan skills directory and register skills
func scanSkills() {
    SKILL_REGISTRY = make(map[string]map[string]interface{})
    if !skillDirExists() {
        return
    }
    for _, dir := range getSortedSkillDirectories() {
        if !isSkillDirectory(dir) {
            continue
        }
        manifest := getSkillManifest(dir)
        if manifest == "" {
            continue
        }
        meta, content := parseFrontmatter(manifest)
        name := getSkillName(meta)
        description := getSkillDescription(meta, content)
        SKILL_REGISTRY[name] = map[string]interface{}{
            "name":        name,
            "description": description,
            "content":    content,
        }
    }
}

// Helper functions for skill loading
func skillDirExists() bool {
    return pathExists(filepath.Join(WORKDIR, "skills"))
}

func getSortedSkillDirectories() []string {
    entries, _ := ioutil.ReadDir(filepath.Join(WORKDIR, "skills"))
    var dirs []string
    for _, entry := range entries {
        if entry.IsDir() {
            dirs = append(dirs, entry.Name())
        }
    }
    sort.Strings(dirs)
    return dirs
}

func isSkillDirectory(dir string) bool {
    return dir != "" && dir != "." && dir != ".."
}

func getSkillManifest(dir string) string {
    manifestPath := filepath.Join(WORKDIR, "skills", dir, "SKILL.md")
    if !filepathExists(manifestPath) {
        return ""
    }
    data, _ := ioutil.ReadFile(manifestPath)
    return string(data)
}

func filepathExists(path string) bool {
    _, err := os.Stat(path)
    return err == nil
}

func getSkillName(meta map[string]interface{}) string {
    if name, ok := meta["name"].(string); ok && name != "" {
        return name
    }
    return "unknown"
}

func getSkillDescription(meta map[string]interface{}, content string) string {
    if desc, ok := meta["description"].(string); ok && desc != "" {
        return desc
    }
    lines := strings.Split(content, "\n")
    for _, line := range lines {
        if strings.HasPrefix(line, "# ") && len(line) > 2 {
            return strings.TrimPrefix(line, "# ")
        }
    }
    return "(no description)"
}

// Calculate cron field matching
func cronFieldMatches(field string, value int) bool {
    if field == "*" {
        return true
    }
    if strings.HasPrefix(field, "*/") {
        stepStr := field[2:]
        if stepStr == "" {
            return false
        }
        step, err := fmt.Sscanf(stepStr, "%d", &step)
        if err != nil || step != 1 || step <= 0 {
            return false
        }
        return value%step == 0
    }
    if strings.Contains(field, ",") {
        for part := range strings.Split(field, ",") {
            if cronFieldMatches(strings.TrimSpace(part), value) {
                return true
            }
        }
        return false
    }
    if strings.Contains(field, "-") {
        parts := strings.Split(field, "-")
        if len(parts) == 2 {
            startVal, err1 := fmt.Sscanf(parts[0], "%d", &startVal)
            endVal, err2 := fmt.Sscanf(parts[1], "%d", &endVal)
            if err1 == nil && err2 == nil && startVal <= value && value <= endVal {
                return true
            }
        }
        return false
    }
    return strings.TrimSpace(field) == string(rune(value))
}

// Cron matching function
func cronMatches(cronExpr string, dt time.Time) bool {
    fields := strings.Split(strings.TrimSpace(cronExpr), " ")
    if len(fields) != 5 {
        return false
    }
    minute, hour, dom, month, dow := fields[0], fields[1], fields[2], fields[3], fields[4]
    
    minuteOk := cronFieldMatches(minute, dt.Minute())
    hourOk := cronFieldMatches(hour, dt.Hour())
    domOk := cronFieldMatches(dom, dt.Day())
    monthOk := cronFieldMatches(month, int(dt.Month()))
    
    if !minuteOk || !hourOk || !monthOk {
        return false
    }
    
    dowVal := (dt.Weekday() + 1) % 7
    dowOk := cronFieldMatches(dow, dowVal)
    
    if dom == "*" && dow == "*" {
        return true
    }
    if dom == "*" {
        return dowOk
    }
    if dow == "*" {
        return domOk
    }
    return domOk || dowOk
}

func (c *CronManager) AddJob(job *CronJob) {
    c.mu.Lock()
    defer c.mu.Unlock()
    c.jobs = append(c.jobs, job)
}

func (c *CronManager) RunSchedule(now time.Time) {
    c.mu.RLock()
    defer c.mu.RUnlock()
    for _, job := range c.jobs {
        if job.LastFired.IsZero() || job.LastFired.Before(now) {
            if cronMatches(job.CronExpr, now) {
                fmt.Printf("Running cron job %s\n", job.ID)
                job.LastFired = now
            }
        }
    }
}